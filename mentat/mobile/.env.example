# Mentat mobile environment config
# Copy to .env and fill in your values

# Required: API base URL for the Mentat backend.
# Must use https:// — plain HTTP is no longer accepted.
# Use your Tailscale machine's HTTPS URL (Tailscale HTTPS certs must be enabled
# in your tailnet: https://tailscale.com/kb/1153/enabling-https)
API_BASE_URL=https://your-machine.your-tailnet.ts.net:4310
